# frozen_string_literal: true
require 'base64'

default_platform(:ios)

# ============ Constants ============

APP_IDENTIFIERS = [
  "de.okfn.niederrhein.moers-festival",
  "de.okfn.niederrhein.moers-festival.Widgets",
  "de.okfn.niederrhein.moers-festival.watchkitapp"
].freeze

DEVICES = {
  "Lennarts iPhone 8"      => "e3f6fe313610d72f847e010d17af266b64781acf",
  "Lennarts iPhone XS"     => "00008020-000C584C2690003A",
  "Lennarts iPad Pro"      => "00008103-001C34490CF1001E",
  "Lennarts iPhone 14 Pro" => "00008120-000E7C8C0E38C01E",
  "Lennarts Apple Watch"   => "00008006-000915E42183002E"
}.freeze

INFO_PLIST_PATHS = [
  "moers festival/Config/Info.plist",
  "moers festival UITests/Info.plist",
  "moers festival Tests/Info.plist"
].freeze

SCREENSHOT_SLOT_MAP = {
  "01-timetable.png"    => "iPhone 17 Pro-0-events.png",
  "02-event-detail.png" => "iPhone 17 Pro-1-event_detail.png",
  "03-info.png"         => "iPhone 17 Pro-2-info.png",
  "04-map.png"          => "iPhone 17 Pro-3-map.png"
}.freeze

# ============ Helpers ============

def increment_build_number_for_plist(path)
  current_build = get_info_plist_value(path: path, key: "CFBundleVersion").to_i
  new_build = (current_build + 1).to_s
  set_info_plist_value(path: path, key: "CFBundleVersion", value: new_build)
  UI.message("Updated build number in #{path}: #{current_build} -> #{new_build}")
end

def match_git_auth
  token = ENV['MATCH_GITHUB_TOKEN']
  Base64.strict_encode64("LambdaDigamma:#{token}")
end

platform :ios do

  # ============ Configuration ============

  desc "Load ASC API Key from base64 env var"
  lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY"],
      is_key_content_base64: true,
      in_house: false
    )
  end

  # ============ Signing ============

  desc "Register development devices with Apple Developer Portal"
  lane :register_dev_devices do
    register_devices(
      team_id: "77N8D7LGCZ",
      devices: DEVICES
    )
  end

  desc "Sync appstore certificates and provisioning profiles"
  lane :match_appstore do
    setup_ci if ENV['CI']
    match(
      type: 'appstore',
      app_identifier: APP_IDENTIFIERS,
      git_basic_authorization: match_git_auth
    )
  end

  desc "Sync development certificates and provisioning profiles"
  lane :match_development do
    setup_ci if ENV['CI']
    match(
      type: 'development',
      app_identifier: APP_IDENTIFIERS,
      git_basic_authorization: match_git_auth,
      force_for_new_devices: true
    )
  end

  desc "Register devices and sync all certificates"
  lane :signing do
    register_dev_devices
    match_development
    match_appstore
  end

  # ============ Versioning ============

  desc "Increment build number across all targets"
  lane :increment_build do
    INFO_PLIST_PATHS.each { |path| increment_build_number_for_plist(path) }
  end

  desc "Increment version number (type: patch, minor, or major)"
  lane :increment_version do |options|
    UI.user_error!("Specify version type: patch, minor, or major") unless options[:type]

    current_version = get_info_plist_value(
      path: INFO_PLIST_PATHS.first,
      key: "CFBundleShortVersionString"
    )

    major, minor, patch = current_version.split('.').map(&:to_i)

    case options[:type]
    when "patch" then patch += 1
    when "minor" then minor += 1; patch = 0
    when "major" then major += 1; minor = 0; patch = 0
    else UI.user_error!("Invalid version type: #{options[:type]}")
    end

    new_version = "#{major}.#{minor}.#{patch}"
    UI.message("Updating version: #{current_version} -> #{new_version}")

    set_info_plist_value(
      path: INFO_PLIST_PATHS.first,
      key: "CFBundleShortVersionString",
      value: new_version
    )
  end

  # ============ Building ============

  desc "Build the app for release"
  lane :build_release do
    gym
  end

  # ============ Distribution ============

  desc "Upload build to TestFlight"
  lane :upload_testflight do
    pilot(skip_waiting_for_build_processing: true)
  end

  desc "Upload release notes to App Store Connect"
  lane :upload_release_notes do
    load_asc_api_key
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      app_identifier: "de.okfn.niederrhein.moers-festival"
    )
  end

  desc "Create a new App Store version if needed"
  lane :ensure_app_version do
    load_asc_api_key
    version_number = get_info_plist_value(
      path: INFO_PLIST_PATHS.first,
      key: "CFBundleShortVersionString"
    )
    deliver(
      skip_metadata: true,
      skip_screenshots: true,
      skip_binary_upload: true,
      force: true,
      run_precheck_before_submit: false,
      skip_app_version_update: false,
      app_version: version_number,
      automatic_release: false
    )
  end

  desc "Sign, build, and upload to TestFlight"
  lane :upload do
    load_asc_api_key
    match_appstore
    build_release
    upload_testflight
  end

  desc "Bump version, build, and upload to TestFlight"
  lane :release do |options|
    ensure_git_status_clean
    ensure_git_branch(branch: 'master')

    increment_build
    increment_version(type: options[:type]) if options[:type]

    upload
  end

  # ============ Screenshots ============

  desc "Capture raw screenshots from simulator (config from Snapfile)"
  lane :capture do
    capture_screenshots
  end

  desc "Render processed stills via Remotion"
  lane :render_stills do
    marketing_dir = File.expand_path("../../../marketing", __dir__)
    sh("cd '#{marketing_dir}' && bun run src/scripts/export-stills.ts --locale de-DE")
    sh("cd '#{marketing_dir}' && bun run src/scripts/export-stills.ts --locale en-US")
  end

  desc "Copy Remotion-rendered stills into the snapshots folder for upload"
  lane :replace_screenshots do
    out_dir = File.join(File.expand_path("../../../marketing", __dir__), "out", "screenshots")
    dest_dir = File.join(__dir__, "snapshots")

    # Map source filenames to destination filenames for each device
    compositions = {
      "moers-festival-17-pro" => "iPhone 17 Pro",
      "moers-festival-17-pro-max" => "iPhone 17 Pro Max"
    }

    slot_names = {
      "01" => "events",
      "02" => "event_detail",
      "03" => "info",
      "04" => "map"
    }

    ["de-DE", "en-US"].each do |locale|
      dest = File.join(dest_dir, locale)
      FileUtils.mkdir_p(dest)
      Dir.glob(File.join(dest, "*.png")).each { |f| File.delete(f) }

      compositions.each do |comp_name, device_name|
        composition_dir = File.join(out_dir, locale, comp_name)
        slot_names.each do |src_num, slot_name|
          src = File.join(composition_dir, "#{src_num}.png")
          dest_name = "#{device_name}-#{src_num.to_i - 1}-#{slot_name}.png"
          if File.exist?(src)
            FileUtils.cp(src, File.join(dest, dest_name))
            UI.message("Copied #{comp_name}/#{src_num}.png -> #{dest_name}")
          else
            UI.warning("Missing: #{src}")
          end
        end
      end

      UI.success("Populated snapshots/#{locale} with processed stills")
    end
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    load_asc_api_key
    deliver(
      skip_metadata: true,
      skip_screenshots: false,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      skip_app_version_update: true,
      automatic_release: false,
      screenshots_path: File.expand_path("snapshots", FastlaneCore::FastlaneFolder.path)
    )
  end

  desc "Full screenshot pipeline: capture, render, replace, upload"
  lane :screenshots_pipeline do
    ensure_app_version
    capture
    render_stills
    replace_screenshots
    upload_screenshots
  end

  # ============ tvOS ============

  desc "Increment tvOS version"
  lane :increment_tvos do |options|
    UI.user_error!("Version parameter is required") unless options[:version]
    set_info_plist_value(
      path: "moers festival tvOS/Info.plist",
      key: "CFBundleShortVersionString",
      value: options[:version]
    )
    git_commit(
      path: ["moers festival tvOS/Info.plist"],
      message: "moers festival tvOS Version #{options[:version]}"
    )
  end

  desc "Increment tvOS build number"
  lane :increment_build_tvos do
    increment_build_number_for_plist("moers festival tvOS/Info.plist")
  end

  desc "Sync development certificates for tvOS"
  lane :match_dev_tvos do
    match(
      type: "development",
      platform: "tvos",
      force_for_new_devices: true,
      git_basic_authorization: match_git_auth
    )
  end

  desc "Release a new version for tvOS"
  lane :release_tvos do |options|
    UI.user_error!("Version parameter is required") unless options[:version]

    ensure_git_status_clean
    ensure_git_branch(branch: 'master')

    increment_build_tvos
    increment_tvos(version: options[:version])

    match(type: "appstore", platform: "tvos", git_basic_authorization: match_git_auth)
    gym(scheme: "moers festival tvOS")
    deliver(platform: "appletvos")
  end

  # ============ Error Handling ============

  error do |lane, exception|
    UI.error("Lane '#{lane}' failed with error: #{exception.message}")
  end

end
