# frozen_string_literal: true
require 'base64'

default_platform(:ios)

# Configuration
APP_IDENTIFIERS = [
  "de.okfn.niederrhein.moers-festival",
  "de.okfn.niederrhein.moers-festival.Widgets",
  "de.okfn.niederrhein.moers-festival.watchkitapp"
].freeze

platform :ios do

  # --- Utilies ---

  def increment_build_number_for_plist(path)
    current_build = get_info_plist_value(path: path, key: "CFBundleVersion").to_i
    new_build = (current_build + 1).to_s

    set_info_plist_value(
      path: path,
      key: "CFBundleVersion",
      value: new_build
    )

    UI.message("Updated build number in #{path}: #{current_build} -> #{new_build}")
  end

  desc "Sync signing"
  lane :signing do
    register_devices(
      team_id: "77N8D7LGCZ",
      devices: {
        "Lennarts iPhone 8" => "e3f6fe313610d72f847e010d17af266b64781acf",
        "Lennarts iPhone XS" => "00008020-000C584C2690003A",
        "Lennarts iPad Pro" => "00008103-001C34490CF1001E",
        "Lennarts iPhone 14 Pro" => "00008120-000E7C8C0E38C01E",
        "Lennarts Apple Watch" => "00008006-000915E42183002E"
      }
    )

    ["development", "appstore"].each do |type|
      sync_code_signing(
        type: type,
        force_for_new_devices: type == "development",
        app_identifier: APP_IDENTIFIERS
      )
    end
  end

  desc "Increment version number (patch, minor, major)"
  lane :increment_version do |options|
    UI.user_error!("Specify version type: patch, minor, or major") unless options[:type]

    # Read current version from Info.plist
    current_version = get_info_plist_value(
      path: "moers festival/Config/Info.plist",
      key: "CFBundleShortVersionString"
    )

    # Parse version components
    major, minor, patch = current_version.split('.').map(&:to_i)

    case options[:type]
    when "patch"
      patch += 1
    when "minor"
      minor += 1
      patch = 0
    when "major"
      major += 1
      minor = 0
      patch = 0
    else
      UI.user_error!("Invalid version type: #{options[:type]}")
    end

    new_version = "#{major}.#{minor}.#{patch}"

    UI.message("Updating version to #{new_version}")

    set_info_plist_value(
      path: "moers festival/Config/Info.plist",
      key: "CFBundleShortVersionString",
      value: new_version
    )
  end

  desc "Increment Build Number"
  lane :increment_build do
    [
      "moers festival/Config/Info.plist",
      "moers festival UITests/Info.plist",
      "moers festival Tests/Info.plist"
    ].each do |plist_path|
      increment_build_number_for_plist(plist_path)
    end
  end

  # --- Distribution ---

  desc "Upload to TestFlight / ASC"
  lane :upload do |options|
    load_asc_api_key()

    require 'base64'

    username = "LambdaDigamma"
    token = ENV['MATCH_GITHUB_TOKEN']
    encoded_credentials = Base64.strict_encode64("#{username}:#{token}")

    setup_ci if ENV['CI']

    match(
      type: 'appstore',
      app_identifier: APP_IDENTIFIERS,
      git_basic_authorization: encoded_credentials
    )
    gym_options = {
      scheme: "moers festival"
    }

    if ENV['CI']
      gym_options[:cloned_source_packages_path] = "./SourcePackages"
      gym_options[:skip_package_dependencies_resolution] = true
      gym_options[:disable_package_automatic_updates] = true
    end

    gym(**gym_options)
    pilot(skip_waiting_for_build_processing: true)
  end

  desc "Load ASC API Key information"
  lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )
  end

  desc "Release a new version of moers festival"
  lane :release do |options|

    ensure_git_status_clean

    ensure_git_branch(branch: 'master')

    version = options[:version]

    increment_build()
    increment(version: version)

    match(type: "appstore")
    gym(scheme: "moers festival")
    pilot(skip_waiting_for_build_processing: true)

  end

  desc "Take screenshots"
  lane :screenshots do

    path = "~/Library/Developer/Xcode/DerivedData/moersfestival"
    scheme = "moers festival UITests"
    devices = [
      "iPhone 17 Pro",
    ]

    run_tests(
      build_for_testing: true,
      code_coverage: false,
      derived_data_path: path,
      devices: devices,
      scheme: scheme
    )

    capture_screenshots(
      devices: devices,
      skip_package_dependencies_resolution: true,
      disable_package_automatic_updates: true,
      derived_data_path: path,
      override_status_bar: true,
      override_status_bar_arguments: "--time 9:41 --dataNetwork wifi --wifiMode active --wifiBars 3 --cellularMode active --cellularBars 4 --batteryState discharging --batteryLevel 100",
      headless: false,
      test_without_building: true
    )
  end

  desc "Upload release notes to App Store Connect (skips binary and screenshots)"
  lane :upload_release_notes do
    load_asc_api_key()
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      app_identifier: "de.okfn.niederrhein.moers-festival"
    )
  end

  desc "Capture and process screenshots only (without upload)"
  lane :capture_screenshots do
    fastlane_dir = __dir__
    screenshots_dir = File.join(fastlane_dir, "screenshots")
    marketing_dir   = File.expand_path("../../../marketing", fastlane_dir)
    out_dir         = File.join(marketing_dir, "out", "screenshots")

    slot_map = {
      "01-timetable.png"    => "iPhone 17 Pro-0-events.png",
      "02-event-detail.png" => "iPhone 17 Pro-1-event_detail.png",
      "03-info.png"         => "iPhone 17 Pro-2-info.png",
      "04-map.png"          => "iPhone 17 Pro-3-map.png"
    }

    # Step 1: Capture raw screenshots from simulator
    screenshots()

    # Step 2: Render processed stills via Remotion
    sh("cd '#{marketing_dir}' && bun run src/scripts/export-stills.ts --locale de-DE && bun run src/scripts/export-stills.ts --locale en-US")

    # Step 3: Replace fastlane screenshots with processed stills
    ["de-DE", "en-US"].each do |locale|
      dest = File.join(screenshots_dir, locale)

      Dir.glob(File.join(dest, "*.png")).each { |f| File.delete(f) }

      slot_map.each do |src_name, dest_name|
        FileUtils.cp(File.join(out_dir, locale, src_name), File.join(dest, dest_name))
      end

      UI.success("Replaced screenshots for #{locale}")
    end
  end

  desc "Full screenshot pipeline: capture, process via Remotion, replace and upload"
  lane :screenshots_pipeline do
    capture_screenshots()
    upload_screenshots()
  end

  desc "Upload screenshots"
  lane :upload_screenshots do
    load_asc_api_key()
    
    deliver(
      skip_metadata: true,
      skip_screenshots: false,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      skip_app_version_update: false,
      automatic_release: false
    )
  end

  # --------- tvOS ----------


  # --- Utilities

  desc "Increment Version tvOS"
  lane :increment_tvos do |options|

    version = options[:version]

    # Set App plist version
    set_info_plist_value(
      path: "moers festival tvOS/Info.plist",
      key: "CFBundleShortVersionString",
      value: version
    )

    # Commit plists to git
    git_commit(
      path: [
        "moers festival tvOS/Info.plist",
      ],
      message: "moers festival tvOS Version #{version} 🚀"
    )

  end

  desc "Increment Build Number"
  lane :increment_build_tvos do
    increment_build_number_for_plist("moers festival tvOS/Info.plist")
  end

  # --- Distribution ---

  desc "Release a new version of moers festival for tvOS"
  lane :release_tvos do |options|

    ensure_git_status_clean

    ensure_git_branch(branch: 'master')

    version = options[:version]

    increment_build_tvos()
    increment_tvos(version: version)

    match(type: "appstore", platform: "tvos")
    gym(scheme: "moers festival tvOS")
    deliver(platform: "appletvos")
    # pilot(skip_waiting_for_build_processing: true)

  end

  desc "Match Development Certificate tvOS"
  lane :match_dev_tvos do |options|
    match(type: "development", platform: "tvos", force_for_new_devices: true)
  end

end
