    "Mein Moers is a nice addition to this app. \nExplore the city with 360° panoramas, find shops and get current parking allocation data." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mein Moers ist eine sinnvolle Ergänzung zu dieser App. \nSuche Geschäfte & Parkplätze mit Live-Daten und bewege Dich mit interaktiven 360° Panoramen durch die Stadt!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
